{
  "name": "my-test-project",
  "version": "1.0.0",
  "description": "Playwright TypeScript Automation Framework",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "smoke": "playwright test tests/smoke",
    "chrome": "playwright test --project=Chromium",
    "headed": "playwright test --headed",
    "debug": "playwright test --debug",
    "ui": "playwright test --ui",
    "report": "playwright show-report reports/html",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure": "npm run allure:generate && npm run allure:open"
  },
  "keywords": [
    "playwright",
    "typescript",
    "automation",
    "testing"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "allure-playwright": "^3.10.1",
    "eslint": "^9.39.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}